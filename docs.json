{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ForgeUI",
  "theme": "palm",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/AmanShakya0018/forgeui"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AmanShakya0018/forgeui"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/animations",
              "concepts/theming",
              "concepts/customization"
            ]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Forms & Input",
            "pages": [
              "components/animated-form",
              "components/animated-otp",
              "components/vault-lock"
            ]
          },
          {
            "group": "Navigation",
            "pages": [
              "components/animated-tabs",
              "components/spectrum-switcher"
            ]
          },
          {
            "group": "Cards",
            "pages": [
              "components/expandable-card",
              "components/fraud-card",
              "components/onboard-card",
              "components/security-card",
              "components/social-card",
              "components/stats-card"
            ]
          },
          {
            "group": "Text Effects",
            "pages": [
              "components/text-reveal",
              "components/text-morph",
              "components/text-shimmer"
            ]
          },
          {
            "group": "Notifications",
            "pages": [
              "components/notification-center",
              "components/notification-panel",
              "components/stack-ripple"
            ]
          },
          {
            "group": "Special Effects",
            "pages": [
              "components/bot-detection",
              "components/framework-agnostic"
            ]
          }
        ]
      }
    ]
  }
}
